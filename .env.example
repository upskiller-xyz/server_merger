
# GCP project ID
PROJECT_ID=xx
GCP_REGION=xx
REPO_NAME=xx-server-docker-repo
IMAGE_NAME=daylight-xx-img
SERVER_NAME=xx-server
# ============================================================================
# Scaleway (SCW) Variables
# Used in: build_scw.sh
# ============================================================================


SCW_PROJECT_ID=xx
SCW_REGISTRY_NAMESPACE=upskiller-nsp
SCW_SERVER=serve-xx-container
SCW_IMAGE=xx-server-image
SCW_SERVE_CONTAINER_NAME=serve-xxx-container

# ============================================================================
# Debug Settings
# ============================================================================

# Enable debug image saving at each processing step (TEMPORARY - for debugging)
# Set to 'true', '1', or 'yes' to enable
# Images will be saved to the debug directory with step names:
#
# Per-window processing steps:
#   - {window_id}_01_original_df.png, {window_id}_01_original_mask.png
#   - {window_id}_02_standardized_df.png, {window_id}_02_standardized_mask.png
#   - {window_id}_03_rotated_df.png, {window_id}_03_rotated_mask.png
#   - {window_id}_04_cropped_df.png, {window_id}_04_cropped_mask.png
#
# Room aggregation steps:
#   - room_00_mask.png (initial room mask)
#   - room_01_after_{window_id}.png (after adding first window)
#   - room_02_after_{window_id}.png (after adding second window)
#   - ... (one image after each window)
#   - room_99_before_mask.png (before applying final mask)
#   - room_final_result.png (final aggregated result)
DEBUG_SAVE_STEPS=false
